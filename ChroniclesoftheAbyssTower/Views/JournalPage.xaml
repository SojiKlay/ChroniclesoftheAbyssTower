<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChroniclesoftheAbyssTower.ViewModels"
             xmlns:models="clr-namespace:ChroniclesoftheAbyssTower.Models"
             x:Class="ChroniclesoftheAbyssTower.Views.JournalPage"
             x:Name="JournalRoot"
             x:DataType="vm:JournalViewModel"
             Title="บันทึก"
             Background="{StaticResource AbyssBackgroundGradient}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True"/>
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

        <Image Source="journal_background.jpg"
               Grid.RowSpan="5"
               Aspect="AspectFill"
               Opacity="0.48"/>

        <BoxView Grid.RowSpan="5"
                 Color="#0E071A"
                 Opacity="0.66"/>

        <!-- ============== Top Back Button ============== -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource AbyssSurface}"
                Stroke="{StaticResource AbyssBorder}"
                StrokeThickness="0,0,0,1"
                Padding="16,12">
            <Button Text="← กลับ"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource ChipButton}"
                    WidthRequest="72"
                    HeightRequest="34"
                    Padding="8,0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"/>
        </Border>

        <!-- ============== Tabs ============== -->
        <Grid Grid.Row="1"
              BackgroundColor="{StaticResource AbyssSurface}"
              ColumnDefinitions="*,*"
              Padding="0">

            <!-- Story Tab -->
            <Grid Grid.Column="0" RowDefinitions="*,Auto">
                <Button Grid.Row="0"
                        Text="{Binding StoryCount, StringFormat='📖 เนื้อเรื่อง ({0})'}"
                        Style="{StaticResource TabButton}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Story">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsStoryTab}"
                                     Value="True">
                            <Setter Property="TextColor" Value="{StaticResource AbyssGold}"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <BoxView Grid.Row="1"
                         HeightRequest="2"
                         Color="{StaticResource AbyssGold}"
                         IsVisible="{Binding IsStoryTab}"/>
            </Grid>

            <!-- Player Tab -->
            <Grid Grid.Column="1" RowDefinitions="*,Auto">
                <Button Grid.Row="0"
                        Text="{Binding PlayerCount, StringFormat='✍️ ของฉัน ({0})'}"
                        Style="{StaticResource TabButton}"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="Player">
                    <Button.Triggers>
                        <DataTrigger TargetType="Button"
                                     Binding="{Binding IsPlayerTab}"
                                     Value="True">
                            <Setter Property="TextColor" Value="{StaticResource AbyssGold}"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <BoxView Grid.Row="1"
                         HeightRequest="2"
                         Color="{StaticResource AbyssGold}"
                         IsVisible="{Binding IsPlayerTab}"/>
            </Grid>
        </Grid>

        <!-- ============== Search ============== -->
        <Border Grid.Row="2"
                Style="{StaticResource AbyssEntry}"
                Margin="16,12,16,4">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                <Label Grid.Column="0" Text="🔍" FontSize="16" VerticalOptions="Center"/>
                <Entry Grid.Column="1"
                       Text="{Binding SearchText, Mode=TwoWay}"
                       Placeholder="ค้นหาบันทึก..."
                       ClearButtonVisibility="WhileEditing"/>
            </Grid>
        </Border>

        <!-- ============== Journal List ============== -->
        <Grid Grid.Row="3">

            <ActivityIndicator IsVisible="{Binding IsBusy}"
                               IsRunning="{Binding IsBusy}"
                               Style="{StaticResource AbyssActivityIndicator}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>

            <!-- Empty State -->
            <VerticalStackLayout IsVisible="{Binding HasNoJournals}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="8"
                                 Padding="20">
                <Label Text="{Binding EmptyMessage}"
                       Style="{StaticResource AbyssCaption}"
                       FontSize="13"
                       HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- Journal List -->
            <CollectionView ItemsSource="{Binding Journals}"
                            Margin="16,8,16,16"
                            SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Journal">
                        <Border Style="{StaticResource AbyssCard}" Padding="14" Margin="0,0,0,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding BindingContext.OpenJournalCommand, Source={x:Reference JournalRoot}}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="4">

                                <!-- Title -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Title}"
                                       TextColor="{StaticResource AbyssGold}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"/>

                                <!-- Floor Badge -->
                                <Border Grid.Row="0" Grid.Column="1"
                                        BackgroundColor="{StaticResource AbyssSurfaceElevated}"
                                        Stroke="{StaticResource AbyssBorder}"
                                        StrokeThickness="1"
                                        Padding="6,2">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="8"/>
                                    </Border.StrokeShape>
                                    <Label Text="{Binding FloorNumber, StringFormat='ชั้น {0}'}"
                                           FontSize="11"
                                           TextColor="{StaticResource AbyssPurpleLight}"/>
                                </Border>

                                <!-- Preview content -->
                                <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding Content}"
                                       Style="{StaticResource AbyssBody}"
                                       FontSize="12"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"
                                       Margin="0,2,0,0"/>

                                <!-- Date -->
                                <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                       Text="{Binding UpdatedAt, StringFormat='แก้ไขล่าสุด: {0:dd MMM yyyy HH:mm}'}"
                                       Style="{StaticResource AbyssCaption}"
                                       FontSize="10"
                                       Margin="0,4,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>

        <!-- ============== Add Button (FAB-like) ============== -->
        <Grid Grid.Row="4"
              IsVisible="{Binding CanAddJournal}"
              Padding="16,12,16,24">
            <Button Text="✍️  เขียนบันทึกใหม่"
                    Style="{StaticResource GoldButton}"
                    Command="{Binding AddJournalCommand}"
                    WidthRequest="220"
                    HorizontalOptions="Center"/>
        </Grid>

    </Grid>

</ContentPage>
