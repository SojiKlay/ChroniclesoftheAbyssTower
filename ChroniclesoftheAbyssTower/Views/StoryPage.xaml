<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChroniclesoftheAbyssTower.ViewModels"
             x:Class="ChroniclesoftheAbyssTower.Views.StoryPage"
             x:Name="StoryRoot"
             x:DataType="vm:StoryViewModel"
             Shell.NavBarIsVisible="False"
             Background="{StaticResource AbyssBackgroundGradient}">

    <Grid RowDefinitions="Auto,*" Padding="0">

        <!-- ============== Top Stats Bar ============== -->
        <Border Grid.Row="0"
                BackgroundColor="{StaticResource AbyssSurface}"
                Stroke="{StaticResource AbyssBorder}"
                StrokeThickness="0,0,0,1"
                Padding="14,8">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="4">

                <!-- Row 1: Player + Floor + Quick Buttons -->
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="0">
                        <Label Text="{Binding PlayerName}"
                               TextColor="{StaticResource AbyssGold}"
                               FontAttributes="Bold"
                               FontSize="14"/>
                        <Label Text="{Binding FloorDisplay}"
                               Style="{StaticResource AbyssCaption}"/>
                    </VerticalStackLayout>

                    <!-- Gold -->
                    <HorizontalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center" Margin="0,0,12,0">
                        <Label Text="💰" FontSize="14" VerticalOptions="Center"/>
                        <Label Text="{Binding Gold}"
                               TextColor="{StaticResource GoldColor}"
                               FontAttributes="Bold"
                               FontSize="13"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Inventory Button -->
                    <Button Grid.Column="2"
                            Text="🎒"
                            Command="{Binding GoToInventoryCommand}"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Padding="6,2"
                            FontSize="20"
                            MinimumWidthRequest="36"
                            HeightRequest="36"
                            VerticalOptions="Center"/>

                    <!-- Journal Button -->
                    <Button Grid.Column="3"
                            Text="📖"
                            Command="{Binding GoToJournalCommand}"
                            BackgroundColor="Transparent"
                            BorderWidth="0"
                            Padding="6,2"
                            FontSize="20"
                            MinimumWidthRequest="36"
                            HeightRequest="36"
                            VerticalOptions="Center"/>

                    <!-- Menu Button -->
                    <Button Grid.Column="4"
                            Text="≡"
                            Command="{Binding BackToMenuCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource TextSecondary}"
                            BorderWidth="0"
                            Padding="6,2"
                            FontSize="22"
                            FontAttributes="Bold"
                            MinimumWidthRequest="36"
                            HeightRequest="36"
                            VerticalOptions="Center"/>
                </Grid>

                <!-- Row 2: HP Bar -->
                <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                    <Label Grid.Column="0"
                           Text="❤️"
                           FontSize="13"
                           VerticalOptions="Center"/>
                    <ProgressBar Grid.Column="1"
                                 Progress="{Binding HpRatio}"
                                 Style="{StaticResource HpProgressBar}"
                                 VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="{Binding HpDisplay}"
                           FontSize="12"
                           TextColor="{StaticResource HpColor}"
                           FontAttributes="Bold"
                           VerticalOptions="Center"/>
                </Grid>

            </Grid>
        </Border>

        <!-- ============== Scrollable Content (Narrative + Choices) ============== -->
        <ScrollView Grid.Row="1" Padding="16,10,16,12">
            <VerticalStackLayout Spacing="10">

                <!-- Floor Header -->
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="{Binding FloorIcon}"
                           IsVisible="{Binding HasFloorIcon}"
                           FontSize="48"
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding FloorTitle}"
                           Style="{StaticResource AbyssSectionHeader}"
                           FontSize="18"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="{Binding EventType}"
                           Style="{StaticResource AbyssCaption}"
                           HorizontalOptions="Center"/>
                    <Border IsVisible="{Binding HasFloorImage}"
                            HeightRequest="200"
                            Margin="0,6,0,0"
                            HorizontalOptions="Fill"
                            Stroke="{StaticResource AbyssBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource AbyssSurface}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14"/>
                        </Border.StrokeShape>
                        <Image Source="{Binding FloorImage}"
                               Aspect="AspectFill"/>
                    </Border>
                    <BoxView HeightRequest="1"
                             Color="{StaticResource AbyssGold}"
                             WidthRequest="60"
                             Opacity="0.5"
                             HorizontalOptions="Center"
                             Margin="0,4"/>
                </VerticalStackLayout>

                <!-- Narrative Card -->
                <Border Style="{StaticResource AbyssStoryCard}" Padding="14">
                    <Label Text="{Binding Narrative}"
                           Style="{StaticResource AbyssStoryText}"
                           FontSize="15"
                           LineHeight="1.35"/>
                </Border>

                <!-- Latest choice feedback -->
                <Border IsVisible="{Binding HasOutcomeFeedback}"
                        BackgroundColor="{StaticResource AbyssSurface}"
                        Stroke="{Binding OutcomeAccentColor}"
                        StrokeThickness="1"
                        Padding="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14"/>
                    </Border.StrokeShape>
                    <Grid ColumnDefinitions="5,*">
                        <BoxView Grid.Column="0"
                                 Color="{Binding OutcomeAccentColor}"
                                 VerticalOptions="Fill"/>
                        <VerticalStackLayout Grid.Column="1" Padding="12,10" Spacing="6">
                            <Label Text="{Binding OutcomeTitle}"
                                   TextColor="{Binding OutcomeAccentColor}"
                                   FontAttributes="Bold"
                                   FontSize="13"/>
                            <Label Text="{Binding OutcomeText}"
                                   Style="{StaticResource AbyssStoryText}"
                                   FontSize="14"
                                   LineHeight="1.25"/>
                            <Label Text="{Binding OutcomeStats}"
                                   IsVisible="{Binding HasOutcomeStats}"
                                   TextColor="{StaticResource TextPrimary}"
                                   FontAttributes="Bold"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                            <Label Text="{Binding OutcomeRewards}"
                                   IsVisible="{Binding HasOutcomeRewards}"
                                   TextColor="{StaticResource AbyssGold}"
                                   FontAttributes="Bold"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Error display -->
                <Label Text="{Binding ErrorMessage}"
                       Style="{StaticResource AbyssError}"
                       IsVisible="{Binding HasError}"
                       HorizontalTextAlignment="Center"/>

                <!-- Choices Section Header -->
                <Label Text="เลือกการตัดสินใจ"
                       Style="{StaticResource AbyssSectionHeader}"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       Margin="0,2,0,0"/>

                <!-- Choices (disable ทั้งหมดเมื่อ IsBusy เพื่อกัน double-tap) -->
                <VerticalStackLayout Spacing="6"
                                     BindableLayout.ItemsSource="{Binding Choices}"
                                     IsEnabled="{Binding IsNotBusy}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChoiceItemVm">
                            <VerticalStackLayout Spacing="3">
                                <Button Text="{Binding Text}"
                                        Style="{StaticResource ChoiceButton}"
                                        FontSize="13"
                                        HeightRequest="44"
                                        MinimumHeightRequest="44"
                                        Padding="12,6"
                                        CornerRadius="10"
                                        IsEnabled="{Binding IsEnabled}"
                                        Command="{Binding BindingContext.SelectChoiceCommand, Source={x:Reference StoryRoot}}"
                                        CommandParameter="{Binding .}"/>
                                <Label Text="{Binding LockReason}"
                                       Style="{StaticResource AbyssCaption}"
                                       TextColor="{StaticResource DangerColor}"
                                       IsVisible="{Binding ShowLockReason}"
                                       HorizontalTextAlignment="Center"
                                       FontSize="11"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ============== Loading Overlay ============== -->
        <Grid Grid.RowSpan="2"
              BackgroundColor="#80000000"
              IsVisible="{Binding IsBusy}">
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               Style="{StaticResource AbyssActivityIndicator}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"/>
        </Grid>

    </Grid>

</ContentPage>
