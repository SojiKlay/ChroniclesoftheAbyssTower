<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChroniclesoftheAbyssTower.ViewModels"
             x:Class="ChroniclesoftheAbyssTower.Views.EndingPage"
             x:DataType="vm:EndingViewModel"
             Shell.NavBarIsVisible="False"
             Background="{StaticResource AbyssBackgroundGradient}">

    <ScrollView>
        <Grid Padding="24,40,24,32" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="20">

            <!-- ============== Header ============== -->
            <VerticalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
                <Label Text="{Binding EndingIcon}"
                       FontSize="92"
                       HorizontalOptions="Center"/>
                <Label Text="{Binding EndingTitle}"
                       Style="{StaticResource AbyssTitle}"
                       FontSize="26"
                       TextColor="{Binding EndingColor}"/>
                <Label Text="{Binding EndingSubtitle}"
                       Style="{StaticResource AbyssSubtitle}"
                       FontSize="13"/>
                <BoxView HeightRequest="2"
                         WidthRequest="100"
                         Color="{Binding EndingColor}"
                         HorizontalOptions="Center"
                         Margin="0,8,0,0"/>
            </VerticalStackLayout>

            <!-- ============== Narrative Card ============== -->
            <Border Grid.Row="1" Style="{StaticResource AbyssStoryCard}" Padding="20,24">
                <Label Text="{Binding EndingNarrative}"
                       Style="{StaticResource AbyssStoryText}"
                       FontSize="15"
                       LineHeight="1.8"
                       HorizontalTextAlignment="Center"/>
            </Border>

            <!-- ============== Stats Summary ============== -->
            <Border Grid.Row="2" Style="{StaticResource AbyssCard}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="สรุปการผจญภัย"
                           Style="{StaticResource AbyssSectionHeader}"
                           FontSize="16"
                           HorizontalTextAlignment="Center"/>

                    <BoxView HeightRequest="1" Color="{StaticResource AbyssBorder}"/>

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="8">
                        <Label Grid.Row="0" Grid.Column="0" Text="ตัวละคร" Style="{StaticResource AbyssCaption}"/>
                        <Label Grid.Row="0" Grid.Column="1" Text="{Binding PlayerNameDisplay}"
                               TextColor="{StaticResource AbyssGold}" FontAttributes="Bold" FontSize="13"/>

                        <Label Grid.Row="1" Grid.Column="0" Text="🎚️ Level สุดท้าย" Style="{StaticResource AbyssCaption}"/>
                        <Label Grid.Row="1" Grid.Column="1" Text="{Binding FinalLevelDisplay}"
                               TextColor="{StaticResource LevelColor}" FontAttributes="Bold" FontSize="13"/>

                        <Label Grid.Row="2" Grid.Column="0" Text="🏆 ชั้นสูงสุดที่ไปถึง" Style="{StaticResource AbyssCaption}"/>
                        <Label Grid.Row="2" Grid.Column="1" Text="{Binding HighestFloorDisplay}"
                               TextColor="{StaticResource AbyssGold}" FontAttributes="Bold" FontSize="13"/>

                        <Label Grid.Row="3" Grid.Column="0" Text="🎲 จำนวนการตัดสินใจ" Style="{StaticResource AbyssCaption}"/>
                        <Label Grid.Row="3" Grid.Column="1" Text="{Binding TotalChoicesDisplay}"
                               TextColor="{StaticResource AbyssPurpleLight}" FontAttributes="Bold" FontSize="13"/>

                        <Label Grid.Row="4" Grid.Column="0" Text="💰 ทองคำสะสม" Style="{StaticResource AbyssCaption}"/>
                        <Label Grid.Row="4" Grid.Column="1" Text="{Binding FinalGoldDisplay}"
                               TextColor="{StaticResource GoldColor}" FontAttributes="Bold" FontSize="13"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- ============== Action Buttons ============== -->
            <VerticalStackLayout Grid.Row="3" Spacing="10" Margin="0,8,0,0">
                <Button Text="🌌  เริ่มเกมใหม่"
                        Style="{StaticResource GoldButton}"
                        Command="{Binding NewGameCommand}"
                        HeightRequest="54"/>

                <Button Text="กลับเมนูหลัก"
                        Style="{StaticResource OutlineButton}"
                        Command="{Binding BackToMenuCommand}"
                        HeightRequest="48"/>
            </VerticalStackLayout>

            <!-- ============== Footer ============== -->
            <Label Grid.Row="4"
                   Text="✦  Chronicles of the Abyss Tower  ✦"
                   Style="{StaticResource AbyssCaption}"
                   HorizontalOptions="Center"
                   Margin="0,12,0,0"/>

        </Grid>
    </ScrollView>

</ContentPage>
