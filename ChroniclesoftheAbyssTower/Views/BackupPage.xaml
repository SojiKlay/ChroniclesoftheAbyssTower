<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ChroniclesoftheAbyssTower.ViewModels"
             x:Class="ChroniclesoftheAbyssTower.Views.BackupPage"
             x:Name="BackupRoot"
             x:DataType="vm:BackupViewModel"
             Title="สำรองข้อมูล"
             Background="{StaticResource AbyssBackgroundGradient}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True"/>
    </Shell.BackButtonBehavior>

    <ScrollView>
        <Grid Padding="20,16,20,24" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="14">

            <!-- ============== Top Back Button ============== -->
            <Button Grid.Row="0"
                    Text="← กลับ"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource ChipButton}"
                    WidthRequest="72"
                    HeightRequest="34"
                    Padding="8,0"
                    HorizontalOptions="Start"
                    VerticalOptions="Center"/>

            <!-- ============== Header ============== -->
            <VerticalStackLayout Grid.Row="1" Spacing="4" HorizontalOptions="Center">
                <Label Text="💾"
                       FontSize="48"
                       HorizontalOptions="Center"/>
                <Label Text="สำรองข้อมูล / กู้คืน"
                       Style="{StaticResource AbyssSectionHeader}"
                       FontSize="20"
                       HorizontalTextAlignment="Center"/>
                <Label Text="ป้องกันข้อมูลหายและย้ายเครื่องได้"
                       Style="{StaticResource AbyssCaption}"
                       FontSize="12"/>
            </VerticalStackLayout>

            <!-- ============== Action Buttons ============== -->
            <VerticalStackLayout Grid.Row="2" Spacing="10">
                <Button Text="📤  ส่งออกข้อมูลสำรองใหม่"
                        Style="{StaticResource GoldButton}"
                        Command="{Binding ExportCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        HeightRequest="52"/>

                <Button Text="📥  นำเข้าจากไฟล์ภายนอก"
                        Style="{StaticResource OutlineButton}"
                        Command="{Binding ImportFromFileCommand}"
                        IsEnabled="{Binding IsNotBusy}"
                        HeightRequest="48"/>
            </VerticalStackLayout>

            <!-- ============== Section Header ============== -->
            <Label Grid.Row="3"
                   Text="📦 ไฟล์ข้อมูลสำรองในเครื่อง"
                   Style="{StaticResource AbyssSectionHeader}"
                   FontSize="14"
                   Margin="0,8,0,0"/>

            <!-- ============== Empty State ============== -->
            <Border Grid.Row="4"
                    Style="{StaticResource AbyssCard}"
                    IsVisible="{Binding HasNoBackups}"
                    Padding="20">
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="📭"
                           FontSize="42"
                           HorizontalOptions="Center"/>
                    <Label Text="ยังไม่มีไฟล์ข้อมูลสำรอง"
                           Style="{StaticResource AbyssCaption}"
                           HorizontalTextAlignment="Center"/>
                    <Label Text="กด 'ส่งออกข้อมูลสำรองใหม่' เพื่อสร้างไฟล์แรก"
                           Style="{StaticResource AbyssCaption}"
                           FontSize="11"
                           HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- ============== Backup Files List ============== -->
            <VerticalStackLayout Grid.Row="5"
                                 Spacing="10"
                                 BindableLayout.ItemsSource="{Binding BackupFiles}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:BackupFileVm">
                        <Border Style="{StaticResource AbyssCard}" Padding="12">
                            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">

                                <!-- File Info -->
                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2">
                                        <Label Text="{Binding FileName}"
                                               TextColor="{StaticResource AbyssGold}"
                                               FontAttributes="Bold"
                                               FontSize="12"
                                               MaxLines="1"
                                               LineBreakMode="TailTruncation"/>
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding DateDisplay}"
                                                   Style="{StaticResource AbyssCaption}"
                                                   FontSize="11"/>
                                            <Label Text="·"
                                                   Style="{StaticResource AbyssCaption}"
                                                   FontSize="11"/>
                                            <Label Text="{Binding SizeDisplay}"
                                                   Style="{StaticResource AbyssCaption}"
                                                   FontSize="11"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>

                                <!-- Actions -->
                                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                    <Button Grid.Column="0"
                                            Text="🔄 กู้คืน"
                                            Style="{StaticResource ChipButton}"
                                            FontSize="11"
                                            HeightRequest="38"
                                            Command="{Binding BindingContext.RestoreCommand, Source={x:Reference BackupRoot}}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="1"
                                            Text="📤 แชร์"
                                            Style="{StaticResource ChipButton}"
                                            FontSize="11"
                                            HeightRequest="38"
                                            Command="{Binding BindingContext.ShareFileCommand, Source={x:Reference BackupRoot}}"
                                            CommandParameter="{Binding .}"/>
                                    <Button Grid.Column="2"
                                            Text="🗑️ ลบ"
                                            Style="{StaticResource ChipButton}"
                                            FontSize="11"
                                            HeightRequest="38"
                                            TextColor="{StaticResource DangerColor}"
                                            Command="{Binding BindingContext.DeleteFileCommand, Source={x:Reference BackupRoot}}"
                                            CommandParameter="{Binding .}"/>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- ============== Error ============== -->
            <Label Grid.Row="6"
                   Text="{Binding ErrorMessage}"
                   Style="{StaticResource AbyssError}"
                   IsVisible="{Binding HasError}"
                   HorizontalTextAlignment="Center"/>

        </Grid>
    </ScrollView>

</ContentPage>
