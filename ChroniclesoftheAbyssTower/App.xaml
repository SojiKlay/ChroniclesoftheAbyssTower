<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ChroniclesoftheAbyssTower"
             xmlns:converters="clr-namespace:ChroniclesoftheAbyssTower.Helpers.Converters"
             x:Class="ChroniclesoftheAbyssTower.App"
             UserAppTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value Converters ใช้ทั่วทั้งแอป -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:StringNotEmptyConverter x:Key="StringNotEmptyConverter"/>
            <converters:HpToColorConverter x:Key="HpToColorConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
